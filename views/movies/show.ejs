<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= movie.title %> - Movie App</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../partials/header') %>

    <main class="container py-5">
        <div class="row">
            <div class="col-md-8 mx-auto">
                <div class="card shadow-lg">
                    <div class="card-body p-5">
                        <div class="row mb-4">
                            <div class="col">
                                <h1 class="card-title"><%= movie.title %></h1>
                            </div>
                            <div class="col-auto">
                                <span class="badge bg-warning text-dark" style="font-size: 1.2em;">
                                    <%= movie.rating %>/10
                                </span>
                            </div>
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-6">
                                <p><strong>Genre:</strong> <span class="badge bg-info"><%= movie.genre %></span></p>
                                <p><strong>Director:</strong> <%= movie.director %></p>
                                <p><strong>Release Date:</strong> <%= new Date(movie.releaseDate).toLocaleDateString() %></p>
                            </div>
                            <div class="col-md-6">
                                <p><strong>Added:</strong> <%= new Date(movie.createdAt).toLocaleDateString() %></p>
                                <p><strong>Last Updated:</strong> <%= new Date(movie.updatedAt).toLocaleDateString() %></p>
                            </div>
                        </div>

                        <% if (movie.review) { %>
                            <div class="mb-4">
                                <h5>Review</h5>
                                <p class="card-text"><%= movie.review %></p>
                            </div>
                        <% } %>

                        <div class="d-grid gap-2 d-sm-flex">
                            <a href="/movies" class="btn btn-secondary">Back to Movies</a>
                            <% if (user) { %>
                                <a href="/movies/<%= movie._id %>/edit" class="btn btn-warning">Edit Movie</a>
                                <form method="POST" action="/movies/<%= movie._id %>?_method=DELETE" style="display: inline;">
                                    <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to delete this movie?')">Delete Movie</button>
                                </form>
                            <% } %>
                        </div>
                    </div>
                </div>

                <% if (user) { %>
                    <div class="alert alert-info mt-4" role="alert">
                        <strong>Note:</strong> The movie title cannot be changed after creation.
                    </div>
                <% } %>
            </div>
        </div>
    </main>

    <footer class="bg-dark text-white text-center py-4 mt-5">
        <p>&copy; 2026 Movie App. All rights reserved.</p>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
