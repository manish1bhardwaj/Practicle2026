<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Movie - Movie App</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../partials/header') %>

    <main class="container py-5">
        <div class="row">
            <div class="col-md-8 mx-auto">
                <div class="card shadow">
                    <div class="card-body p-5">
                        <h2 class="card-title mb-4">Add New Movie</h2>

                        <% if (locals.message) { %>
                            <div class="alert alert-danger" role="alert">
                                <%= message %>
                            </div>
                        <% } %>

                        <form method="POST" action="/movies" novalidate>
                            <div class="mb-3">
                                <label for="title" class="form-label">Title *</label>
                                <input type="text" class="form-control" id="title" name="title" 
                                       required placeholder="Movie title"
                                       value="<%= locals.title || '' %>">
                                <div class="invalid-feedback">
                                    Title is required.
                                </div>
                            </div>

                            <div class="mb-3">
                                <label for="genre" class="form-label">Genre *</label>
                                <select class="form-select" id="genre" name="genre" required>
                                    <option value="">Select a genre</option>
                                    <option value="Action" <%= locals.genre === 'Action' ? 'selected' : '' %>>Action</option>
                                    <option value="Comedy" <%= locals.genre === 'Comedy' ? 'selected' : '' %>>Comedy</option>
                                    <option value="Drama" <%= locals.genre === 'Drama' ? 'selected' : '' %>>Drama</option>
                                    <option value="Horror" <%= locals.genre === 'Horror' ? 'selected' : '' %>>Horror</option>
                                    <option value="Romance" <%= locals.genre === 'Romance' ? 'selected' : '' %>>Romance</option>
                                    <option value="Sci-Fi" <%= locals.genre === 'Sci-Fi' ? 'selected' : '' %>>Sci-Fi</option>
                                    <option value="Thriller" <%= locals.genre === 'Thriller' ? 'selected' : '' %>>Thriller</option>
                                    <option value="Animation" <%= locals.genre === 'Animation' ? 'selected' : '' %>>Animation</option>
                                    <option value="Documentary" <%= locals.genre === 'Documentary' ? 'selected' : '' %>>Documentary</option>
                                    <option value="Adventure" <%= locals.genre === 'Adventure' ? 'selected' : '' %>>Adventure</option>
                                </select>
                                <div class="invalid-feedback">
                                    Please select a genre.
                                </div>
                            </div>

                            <div class="mb-3">
                                <label for="releaseDate" class="form-label">Release Date *</label>
                                <input type="date" class="form-control" id="releaseDate" name="releaseDate" 
                                       required value="<%= locals.releaseDate || '' %>">
                                <div class="invalid-feedback">
                                    Release date is required.
                                </div>
                            </div>

                            <div class="mb-3">
                                <label for="director" class="form-label">Director *</label>
                                <input type="text" class="form-control" id="director" name="director" 
                                       required placeholder="Director name"
                                       value="<%= locals.director || '' %>">
                                <div class="invalid-feedback">
                                    Director is required.
                                </div>
                            </div>

                            <div class="mb-3">
                                <label for="rating" class="form-label">Rating (1-10) *</label>
                                <input type="number" class="form-control" id="rating" name="rating" 
                                       required min="1" max="10" step="0.1" placeholder="e.g., 8.5"
                                       value="<%= locals.rating || '' %>">
                                <small class="form-text text-muted">Enter a rating between 1 and 10</small>
                                <div class="invalid-feedback">
                                    Rating must be between 1 and 10.
                                </div>
                            </div>

                            <div class="mb-3">
                                <label for="review" class="form-label">Review</label>
                                <textarea class="form-control" id="review" name="review" 
                                          rows="4" placeholder="Share your thoughts about the movie"
                                          maxlength="1000"><%= locals.review || '' %></textarea>
                                <small class="form-text text-muted">Maximum 1000 characters</small>
                            </div>

                            <div class="d-grid gap-2 d-sm-flex justify-content-sm-end">
                                <a href="/movies" class="btn btn-secondary">Cancel</a>
                                <button type="submit" class="btn btn-primary">Add Movie</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script>
        (function() {
            'use strict';
            window.addEventListener('load', function() {
                const forms = document.querySelectorAll('form');
                Array.prototype.slice.call(forms).forEach(function(form) {
                    form.addEventListener('submit', function(event) {
                        if (!form.checkValidity()) {
                            event.preventDefault();
                            event.stopPropagation();
                        }
                        form.classList.add('was-validated');
                    }, false);
                });
            });
        })();
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
